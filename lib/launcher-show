#!/usr/bin/env bash
# Show agent plist contents
# USAGE: launcher show <name>

set -euo pipefail
SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib-cli.bash" --auto "$@"
source "$SCRIPT_DIR/lib-plist.bash"

name="${1:-}"
[[ -z "$name" ]] && usage

plist="$(launcher_plist "$name")"
if [[ ! -f "$plist" ]]; then
  echo "Not found: $name"
  exit 1
fi

cat "$plist"
