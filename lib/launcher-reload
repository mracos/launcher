#!/usr/bin/env bash
# Reload an agent
# USAGE: launcher reload <name|--all>
#
# COMPLETE:
#   1 _launcher_agent_names_or_all

set -euo pipefail
SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib-cli.bash" --auto "$@"
source "$SCRIPT_DIR/lib-plist.bash"

_reload_one() {
  local name="$1"
  local installed_plist="${LAUNCHER_INSTALL_DIR}/${LAUNCHER_PREFIX}.${name}.plist"

  if [[ ! -f "$installed_plist" ]]; then
    echo "Not linked: $name (run 'launcher link $name' first)"
    return 1
  fi

  launchctl unload "$installed_plist" 2>/dev/null
  launchctl load "$installed_plist"
  echo "Reloaded: $name"
}

name="${1:-}"
[[ -z "$name" ]] && usage

if [[ "$name" == "--all" ]]; then
  for f in "$LAUNCHER_INSTALL_DIR"/${LAUNCHER_PREFIX}.*.plist; do
    [[ -f "$f" ]] || continue
    n="$(basename "$f" .plist)"
    n="${n#${LAUNCHER_PREFIX}.}"
    _reload_one "$n"
  done
else
  _reload_one "$name" || exit 1
fi
