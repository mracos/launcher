#!/usr/bin/env bash
# Reload an agent
# USAGE: launcher reload <name>

set -euo pipefail
SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../shared/lib-cli.bash" --auto "$@"
source "$SCRIPT_DIR/lib-plist.bash"

name="${1:-}"
[[ -z "$name" ]] && usage

installed_plist="${LAUNCHER_INSTALL_DIR}/${LAUNCHER_PREFIX}.${name}.plist"
if [[ ! -f "$installed_plist" ]]; then
  echo "Not linked: $name (run 'launcher link $name' first)"
  exit 1
fi

launchctl unload "$installed_plist" 2>/dev/null
launchctl load "$installed_plist"
echo "Reloaded: $name"
