#!/usr/bin/env bash
# Edit agent plist in $EDITOR
# USAGE: launcher edit <name>

set -euo pipefail
SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$(dirname "$SCRIPT_DIR")/shared/lib-cli.bash" --auto "$@"
source "$SCRIPT_DIR/lib-plist.bash"

name="${1:-}"
[[ -z "$name" ]] && usage

plist="$(launcher_plist "$name")"
if [[ ! -f "$plist" ]]; then
  echo "Not found: $name"
  exit 1
fi

${EDITOR:-vim} "$plist"
