#!/usr/bin/env bash
# Unload an agent
# USAGE: launcher unload <name>

set -euo pipefail
SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$(dirname "$SCRIPT_DIR")/shared/lib-cli.bash" --auto "$@"
source "$SCRIPT_DIR/lib-plist.bash"
source "$SCRIPT_DIR/lib-launchd.bash"

name="${1:-}"
[[ -z "$name" ]] && usage

installed_plist="${LAUNCHER_INSTALL_DIR}/${LAUNCHER_PREFIX}.${name}.plist"

# If plist is linked, unload via plist
if [[ -f "$installed_plist" ]]; then
  launchctl unload "$installed_plist" 2>/dev/null
  echo "Unloaded: $name"
  exit 0
fi

# Fallback: bootout orphaned loaded job
label="${LAUNCHER_PREFIX}.${name}"
uid="$(id -u)"

if launcher_loaded_names | grep -Fxq "$name"; then
  if launchctl bootout "gui/${uid}/${label}" 2>/dev/null || launchctl remove "$label" 2>/dev/null; then
    echo "Unloaded: $name"
    exit 0
  fi
  echo "Failed to unload loaded job: $name"
  exit 1
fi

echo "Not linked: $name"
exit 1
