#!/usr/bin/env bash
# Remove symlink from ~/Library/LaunchAgents
# USAGE: launcher unlink <name|--all>

set -euo pipefail
SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib-cli.bash" --auto "$@"
source "$SCRIPT_DIR/lib-plist.bash"

_unlink_one() {
  local name="$1"
  local installed_bin installed_plist
  installed_bin="$(launcher_installed_bin "$name")"
  installed_plist="${LAUNCHER_INSTALL_DIR}/${LAUNCHER_PREFIX}.${name}.plist"

  launchctl unload "$installed_plist" 2>/dev/null || true
  rm -f "$installed_bin" "$installed_plist"
  echo "Unlinked: $name"
}

name="${1:-}"
[[ -z "$name" ]] && usage

if [[ "$name" == "--all" ]]; then
  for f in "$LAUNCHER_DIR"/${LAUNCHER_PREFIX}.*.plist; do
    [[ -f "$f" ]] || continue
    n="$(basename "$f" .plist)"
    n="${n#${LAUNCHER_PREFIX}.}"
    _unlink_one "$n"
  done
else
  _unlink_one "$name"
fi
