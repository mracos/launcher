#!/usr/bin/env bash
# Show agent logs (follow with -f)
# USAGE: launcher logs <name> [-f]
#
# COMPLETE:
#   1 _launcher_agent_names

set -euo pipefail
SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib-cli.bash" --auto "$@"
source "$SCRIPT_DIR/lib-plist.bash"
source "$SCRIPT_DIR/lib-launchd.bash"

name="${1:-}"
[[ -z "$name" ]] && usage

follow=false
shift || true
[[ "${1:-}" == "-f" ]] && follow=true

plist="$(launcher_plist "$name")"
if [[ ! -f "$plist" ]]; then
  echo "Not found: $name"
  exit 1
fi

# Get log path from launchd or plist
info="$(launcher_launchd_info "$name")"
stdout_path="$(echo "$info" | grep "^stdout_path=" | cut -d= -f2-)"

if [[ -z "$stdout_path" ]]; then
  stdout_path="$(/usr/libexec/PlistBuddy -c "Print :StandardOutPath" "$plist" 2>/dev/null || echo "")"
fi

if [[ -z "$stdout_path" ]]; then
  echo "No log path configured for $name"
  echo "Add StandardOutPath/StandardErrorPath to the plist"
  exit 1
fi

if [[ ! -f "$stdout_path" ]]; then
  echo "Log file not found: $stdout_path"
  exit 1
fi

if $follow; then
  tail -f "$stdout_path"
else
  tail -20 "$stdout_path"
fi
