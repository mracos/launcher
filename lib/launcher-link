#!/usr/bin/env bash
# Symlink agent to ~/Library/LaunchAgents
# USAGE: launcher link <name|--all>

set -euo pipefail
SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib-cli.bash" --auto "$@"
source "$SCRIPT_DIR/lib-plist.bash"

_link_one() {
  local name="$1"
  local bin plist installed_bin installed_plist
  bin="$(launcher_bin "$name")"
  plist="$(launcher_plist "$name")"
  installed_bin="$(launcher_installed_bin "$name")"
  installed_plist="${LAUNCHER_INSTALL_DIR}/${LAUNCHER_PREFIX}.${name}.plist"

  if [[ ! -f "$plist" ]]; then
    echo "Not found: $name"
    return 1
  fi

  # No-op when source and install dirs are the same (standalone mode)
  if [[ "$LAUNCHER_DIR" == "$LAUNCHER_INSTALL_DIR" ]]; then
    echo "$name: already in place"
    return 0
  fi

  # Idempotent - skip if already linked correctly
  if [[ -L "$installed_plist" && "$(readlink "$installed_plist")" == "$plist" ]]; then
    return 0
  fi

  mkdir -p "$LAUNCHER_INSTALL_DIR"
  ln -sf "$bin" "$installed_bin"
  ln -sf "$plist" "$installed_plist"
  echo "Linked: $name"
}

name="${1:-}"
[[ -z "$name" ]] && usage

if [[ "$name" == "--all" ]]; then
  for f in "$LAUNCHER_DIR"/${LAUNCHER_PREFIX}.*.plist; do
    [[ -f "$f" ]] || continue
    n="$(basename "$f" .plist)"
    n="${n#${LAUNCHER_PREFIX}.}"
    _link_one "$n"
  done
else
  _link_one "$name"
fi
