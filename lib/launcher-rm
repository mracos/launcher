#!/usr/bin/env bash
# Remove an agent (unload, delete plist and bin)
# USAGE: launcher rm <name>

set -euo pipefail
SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$(dirname "$SCRIPT_DIR")/shared/lib-cli.bash" --auto "$@"
source "$SCRIPT_DIR/lib-plist.bash"

name="${1:-}"
[[ -z "$name" ]] && usage

plist="$(launcher_plist "$name")"
if [[ ! -f "$plist" ]]; then
  echo "Not found: $name"
  exit 1
fi

bin="$(launcher_bin "$name")"
launchctl unload "$plist" 2>/dev/null || true
rm -f "$plist" "$bin"
echo "Removed: $name"
