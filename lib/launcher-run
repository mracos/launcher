#!/usr/bin/env bash
# Run agent command manually
# USAGE: launcher run <name>

set -euo pipefail
SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../shared/lib-cli.bash" --auto "$@"
source "$SCRIPT_DIR/lib-plist.bash"

name="${1:-}"
[[ -z "$name" ]] && usage

bin="$(launcher_bin "$name")"
if [[ ! -f "$bin" ]]; then
  echo "Not found: $name"
  exit 1
fi

"$bin"
